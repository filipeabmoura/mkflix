{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mk/model": ["packages/model/src"],
      "@mk/database": ["packages/database/src"],
      "@mk/utils": ["packages/utils/src"]
    }
  }
}
